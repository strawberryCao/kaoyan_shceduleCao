{
  "name": "kaoyan-schedule-app",
  "version": "1.0.0",
  "description": "考研学习课表的置顶小笔记窗",
  "author": "Codex",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "node scripts/fix-learning-record-migration-runner.cjs && node scripts/ensure-source-invariants.cjs && node scripts/publish-learning-record-migration-export.cjs",
    "dev": "vite --config vite.config.mjs",
    "runtime:build": "node scripts/ensure-web-build.cjs",
    "runtime:serve": "node scripts/web-server.cjs",
    "note:server": "node scripts/note-server.cjs",
    "notes:organize": "node scripts/organize-notes.cjs --force",
    "notes:organize:preview": "node scripts/organize-notes.cjs --dry-run",
    "notes:index": "node scripts/rebuild-note-index.cjs --apply",
    "notes:index:preview": "node scripts/rebuild-note-index.cjs",
    "notes:folder-sync:install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/install-note-folder-sync.ps1",
    "notes:folder-sync:run": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows-note-folder-sync.ps1",
    "learning:merge": "node scripts/merge-learning-data.cjs",
    "review:push": "node scripts/review-github-sync.cjs push",
    "review:pull": "node scripts/review-github-sync.cjs pull",
    "review:status": "node scripts/review-github-sync.cjs status",
    "test:gemini": "node scripts/test-gemini.cjs",
    "test:kimi": "node scripts/test-kimi.cjs",
    "build": "tsc -p tsconfig.json --noEmit && vite build --config vite.config.mjs",
    "cloudflare:types": "wrangler types",
    "cloudflare:dev": "npm run build && wrangler dev",
    "cloudflare:deploy": "npm run build && wrangler deploy",
    "cloudflare:seed:prepare": "node scripts/prepare-cloudflare-seed.cjs",
    "cloudflare:seed:upload": "node scripts/upload-cloudflare-seed.cjs",
    "build:wallpaper": "npm run build",
    "electron:dev": "concurrently -k \"vite --config vite.config.mjs --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && electron . --note-app\"",
    "desktop:start": "npm run build && electron . --note-app",
    "desktop:build": "npm run build && electron-builder --win --dir",
    "preview": "vite preview --config vite.config.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "heic-to": "^1.5.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "wait-on": "^8.0.1",
    "wrangler": "^4.113.0"
  },
  "build": {
    "appId": "com.local.kaoyan.schedule",
    "productName": "考研置顶笔记台",
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "scripts/note-file-access.cjs",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "dir"
      ]
    }
  }
}
