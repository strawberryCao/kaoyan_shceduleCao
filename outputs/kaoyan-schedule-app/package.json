{
  "name": "kaoyan-schedule-app",
  "version": "1.0.0",
  "description": "考研学习课表桌面组件",
  "author": "Codex",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --config vite.config.mjs",
    "note:server": "node scripts/note-server.cjs",
    "build": "tsc -p tsconfig.json --noEmit && vite build --config vite.config.mjs",
    "build:wallpaper": "npm run build",
    "electron:dev": "concurrently -k \"vite --config vite.config.mjs --host 127.0.0.1 --port 5173\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "desktop:start": "npm run build && electron .",
    "desktop:build": "npm run build && electron-builder --win --dir",
    "preview": "vite preview --config vite.config.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.11"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.local.kaoyan.schedule",
    "productName": "考研学习课表",
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "dir"
      ]
    }
  }
}
