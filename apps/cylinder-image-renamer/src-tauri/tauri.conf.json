{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI 缸号图片整理器",
  "version": "0.1.0",
  "identifier": "com.strawberrycao.cylinder-image-renamer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI 缸号图片整理器",
        "width": 1440,
        "height": 900,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "shortDescription": "使用云端千问模型识别缸号并按规则批量命名图片",
    "longDescription": "轻量 Windows 缸号图片命名辅助工具。稳定结果自动通过，冲突或无法读取的图片交给用户填写。",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    }
  }
}
